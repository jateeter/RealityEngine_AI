{
  "name": "RS Flip-Flop",
  "description": "Reset-Set flip-flop demonstrating bistable memory",
  "type": "sequential-logic",
  "metadata": {
    "component": "rs-flipflop",
    "inputs": ["S", "R"],
    "outputs": ["Q", "Q_bar"],
    "states": ["SET", "RESET", "HOLD", "INVALID"],
    "inputDimension": 2,
    "outputDimension": 2
  },
  "truthTable": {
    "SR_00": {
      "input": [0, 0],
      "output": "Previous state (HOLD)",
      "description": "Memory - maintains last state"
    },
    "SR_01": {
      "input": [0, 1],
      "output": [0, 1],
      "state": "RESET",
      "description": "Q=0, Q'=1"
    },
    "SR_10": {
      "input": [1, 0],
      "output": [1, 0],
      "state": "SET",
      "description": "Q=1, Q'=0"
    },
    "SR_11": {
      "input": [1, 1],
      "output": [1, 1],
      "state": "INVALID",
      "description": "Undefined - avoid this state"
    }
  },
  "testVectors": [
    {
      "name": "Initial Reset",
      "input": [0, 1],
      "expectedOutput": [0, 1],
      "expectedState": "RESET"
    },
    {
      "name": "Hold from Reset",
      "input": [0, 0],
      "expectedOutput": [0, 1],
      "expectedState": "HOLD_RESET"
    },
    {
      "name": "Set",
      "input": [1, 0],
      "expectedOutput": [1, 0],
      "expectedState": "SET"
    },
    {
      "name": "Hold from Set",
      "input": [0, 0],
      "expectedOutput": [1, 0],
      "expectedState": "HOLD_SET"
    },
    {
      "name": "Reset Again",
      "input": [0, 1],
      "expectedOutput": [0, 1],
      "expectedState": "RESET"
    },
    {
      "name": "Invalid State",
      "input": [1, 1],
      "expectedOutput": [1, 1],
      "expectedState": "INVALID",
      "warning": "This state should be avoided"
    }
  ],
  "sequences": [
    {
      "name": "Basic Toggle",
      "description": "Toggle between SET and RESET",
      "steps": [
        {"input": [0, 1], "comment": "Start with RESET"},
        {"input": [1, 0], "comment": "SET"},
        {"input": [0, 1], "comment": "RESET"},
        {"input": [1, 0], "comment": "SET"},
        {"input": [0, 1], "comment": "RESET"}
      ]
    },
    {
      "name": "Memory Demonstration",
      "description": "Show how the flip-flop holds state",
      "steps": [
        {"input": [1, 0], "comment": "SET to 1"},
        {"input": [0, 0], "comment": "HOLD - remains 1"},
        {"input": [0, 0], "comment": "HOLD - still 1"},
        {"input": [0, 0], "comment": "HOLD - still 1"},
        {"input": [0, 1], "comment": "RESET to 0"},
        {"input": [0, 0], "comment": "HOLD - remains 0"},
        {"input": [0, 0], "comment": "HOLD - still 0"}
      ]
    },
    {
      "name": "Invalid State Recovery",
      "description": "Enter and recover from invalid state",
      "steps": [
        {"input": [1, 0], "comment": "SET"},
        {"input": [1, 1], "comment": "INVALID - both high"},
        {"input": [0, 1], "comment": "Recover to RESET"}
      ]
    }
  ],
  "implementation": {
    "vectors": [
      {
        "id": "reset-state",
        "input": [0, 1],
        "output": [0, 1],
        "state": "RESET",
        "isInitial": true,
        "description": "R=1, S=0: Output Q=0, Q'=1"
      },
      {
        "id": "set-state",
        "input": [1, 0],
        "output": [1, 0],
        "state": "SET",
        "isInitial": true,
        "description": "S=1, R=0: Output Q=1, Q'=0"
      },
      {
        "id": "hold-from-reset",
        "input": [0, 0],
        "output": [0, 1],
        "state": "HOLD_RESET",
        "isInitial": false,
        "description": "S=0, R=0: Maintain RESET state"
      },
      {
        "id": "hold-from-set",
        "input": [0, 0],
        "output": [1, 0],
        "state": "HOLD_SET",
        "isInitial": false,
        "description": "S=0, R=0: Maintain SET state"
      },
      {
        "id": "invalid-state",
        "input": [1, 1],
        "output": [1, 1],
        "state": "INVALID",
        "isInitial": false,
        "description": "S=1, R=1: Invalid/undefined state"
      }
    ]
  },
  "visualization": {
    "nodeColors": {
      "RESET": "#ef4444",
      "SET": "#22c55e",
      "HOLD": "#3b82f6",
      "INVALID": "#f59e0b"
    },
    "layout": "force-directed",
    "showTransitions": true
  },
  "CriticalEventSequences": {
    "SequenceA": {
      "pattern": "[(00,01) -> (10)]",
      "inputs": [[0, 0], [0, 1]],
      "expectedOutput": [1, 0],
      "description": "HOLD then RESET sequence expecting SET output"
    },
    "SequenceB": {
      "pattern": "[(00,10) -> (01)]",
      "inputs": [[0, 0], [1, 0]],
      "expectedOutput": [0, 1],
      "description": "HOLD then SET sequence expecting RESET output"
    }
  },
  "notes": [
    "The RS flip-flop is the simplest form of bistable memory",
    "It has two stable states: SET (Q=1) and RESET (Q=0)",
    "The HOLD state (S=0, R=0) maintains the previous state",
    "The INVALID state (S=1, R=1) should be avoided in practice",
    "This forms the basis for more complex flip-flops (D, JK, T)",
    "Used in memory cells, debouncing, and control systems"
  ]
}

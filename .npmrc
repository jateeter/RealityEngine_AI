# Force npm to honour the `engines.node` constraint declared in package.json.
# With `engine-strict=true`, `npm install` / `npm ci` / `npm run build` refuse
# to run when Node is below the pinned 25.5.0 baseline.  Pair with the
# `.nvmrc` (25.5) so `nvm use` picks the right interpreter in dev shells.
engine-strict=true

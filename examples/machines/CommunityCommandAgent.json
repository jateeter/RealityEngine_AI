{
  "version": "1.0.0",
  "machine": {
    "id": "machine-community-command-agent",
    "name": "Community Command Agent",
    "description": "Meta-CES — orchestrates a referral workflow across community-services leaf machines.  Its 'inputs' are event-bus bits latched by the engine when {benefits-eligibility, intake-triage, housing-placement} sequences fire.  Asserts referral-complete when all three milestones have fired in order.",
    "metadata": {
      "category": "meta-ces",
      "domain": "community-services",
      "compose": {
        "version": "1.0.0",
        "description": "Each subscription latches `1.0` at bitOffset in the perceptual space whenever the producer's sequence fires.  The meta-machine's perceptualMapping.input region covers those bits, so the meta-CES sees fire-events as ordinary input.",
        "subscriptions": [
          {
            "producerMachineId": "machine-benefits-eligibility",
            "producerSequenceId": "bel-finalize",
            "bitOffset": 5500
          },
          {
            "producerMachineId": "machine-intake-triage",
            "producerSequenceId": "intake-finalize",
            "bitOffset": 5501
          },
          {
            "producerMachineId": "machine-housing-placement",
            "producerSequenceId": "housing-place",
            "bitOffset": 5502
          }
        ]
      },
      "tagging": {
        "schemaVersion": "1.0.0",
        "primaryDomain": "community-services",
        "domainTags": [
          "community-services"
        ],
        "family": "command-agent",
        "machineCode": "community-command-agent",
        "capabilityTags": [
          "meta-ces",
          "composition",
          "referral-orchestration"
        ],
        "workflowTags": [
          "referral-workflow",
          "case-coordination"
        ],
        "validationTags": [
          "startup-loadable"
        ]
      },
      "governance": {
        "schemaVersion": "1.0.0",
        "ownerTeam": "social-services-on-call",
        "runbook": "https://runbooks.example.org/community-services/communitycommandagent",
        "escalationPolicy": "pagerduty:social-services",
        "contact": {
          "primary": "social-services-on-call-primary@example.org",
          "secondary": "social-services-on-call-secondary@example.org"
        },
        "sla": {
          "ok": null,
          "info": null,
          "warning": 1800,
          "error": 600
        },
        "notes": "Auto-backfilled by scripts/backfill-governance.mjs from primaryDomain=\"community-services\".  Review and tune the routing as the team owning CommunityCommandAgent matures."
      },
      "triggerConfig": {
        "processId": "COMMUNITYCOMMANDAGENT",
        "processName": "Community Command Agent",
        "rules": [
          {
            "sequenceId": "referral-completion",
            "outputMatches": [
              1,
              0,
              0,
              0
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "All three milestones (benefits, intake, housing) have been confirmed.  Hand off to case management."
          },
          {
            "sequenceId": "referral-incomplete",
            "outputMatches": [
              0,
              1,
              0,
              0
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "info",
            "description": "No milestones latched yet — workflow not started."
          }
        ]
      }
    },
    "arbiterRule": "PASSTHROUGH",
    "perceptualMapping": {
      "input": {
        "offset": 5500,
        "length": 3
      },
      "output": {
        "offset": 5503,
        "length": 4
      },
      "bitsPerElement": 1
    },
    "sequences": [
      {
        "id": "referral-completion",
        "name": "Referral completion — all three milestones latched",
        "metadata": {
          "description": "The meta-CES asserts referral-complete once {benefits-eligible.fired, intake-complete.fired, housing-placed.fired} have all been latched on the event bus.  Latching is monotonic — once a producer fires, the bit stays 1 until the simulator is reset — so this conjunction terminates the workflow regardless of arrival order.  Order discipline (benefits → intake → housing) is enforced upstream by the producer agents, not by the meta-CES."
        },
        "vectors": [
          {
            "id": "ccr-all-milestones-reached",
            "isInitial": true,
            "elements": [
              {
                "value": 1,
                "threshold": 0.5
              },
              {
                "value": 1,
                "threshold": 0.5
              },
              {
                "value": 1,
                "threshold": 0.5
              }
            ],
            "outputVectors": [
              {
                "id": "ccr-out-referral-complete",
                "vector": [
                  1,
                  0,
                  0,
                  0
                ],
                "metadata": {
                  "label": "REFERRAL_COMPLETE",
                  "severity": "INFO",
                  "description": "All three milestones (benefits, intake, housing) have been confirmed.  Hand off to case management."
                }
              }
            ]
          }
        ]
      },
      {
        "id": "referral-incomplete",
        "name": "Referral incomplete — milestones missing",
        "metadata": {
          "description": "Continuously asserts that referral is NOT complete (terminal value [0,1,0,0]) while at least one milestone is unmet.  Pairs with the referral-completion sequence on the same output region — final write wins per merge ordering, so once all three latch, REFERRAL_COMPLETE supersedes."
        },
        "vectors": [
          {
            "id": "ccr-await-all",
            "isInitial": true,
            "elements": [
              {
                "value": 0,
                "threshold": 0.5
              },
              {
                "value": 0,
                "threshold": 0.5
              },
              {
                "value": 0,
                "threshold": 0.5
              }
            ],
            "outputVectors": [
              {
                "id": "ccr-out-referral-pending",
                "vector": [
                  0,
                  1,
                  0,
                  0
                ],
                "metadata": {
                  "label": "REFERRAL_PENDING",
                  "severity": "INFO",
                  "description": "No milestones latched yet — workflow not started."
                }
              }
            ]
          }
        ]
      }
    ]
  }
}

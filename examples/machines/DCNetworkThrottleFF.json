{
  "version": "1.0.0",
  "machine": {
    "name": "DC Network Throttle Flip-Flop",
    "description": "RS flip-flop that latches the network burst alarm state. SET by DCNetworkBurstDetector [1,0], RESET by normal-flow signal [0,1].",
    "metadata": {
      "category": "digital-logic",
      "domain": "Data Center — Network / Throttle Control",
      "author": "Reality Engine",
      "created": "2026-02-27T00:00:00Z",
      "eventSpace": "2D binary control signal at [64:66]: [1,0]=ALARM, [0,1]=SAFE",
      "outputSpace": "2D binary at [102:104]: [1,0]=THROTTLE_ACTIVE, [0,1]=THROTTLE_OFF",
      "tags": [
        "flip-flop",
        "digital-logic",
        "data-center",
        "network"
      ],
      "sequenceCount": 2,
      "role": "Latches network burst alarm; downstream input to DCCriticalSynthesizer",
      "upstreamMachine": "DCNetworkBurstDetector (writes [64:66])",
      "downstreamMachine": "DCCriticalSynthesizer (reads [102:104])",
      "singleTransitionAssumption": {
        "required": false,
        "scope": "not applicable — all event vectors are isInitial (combinatorial)",
        "compliant": true,
        "notes": "Both SET and RESET events are isInitial. The FF responds combinatorially on every cycle. The 'state' persists through the perceptual space value retention: once SET writes [1,0] to [102:104], that value remains until RESET overwrites it with [0,1]."
      }
    },
    "arbiterRule": "PASSTHROUGH",
    "perceptualMapping": {
      "input": {
        "offset": 64,
        "length": 2
      },
      "output": {
        "offset": 102,
        "length": 2
      }
    },
    "sequences": [
      {
        "id": "dc-net-throttle-set-sequence",
        "name": "NETWORK THROTTLE SET: [1,0] → [1,0]",
        "metadata": {
          "description": "Activates network throttle when burst detector fires [1,0] control signal",
          "path": "[1,0] → [1,0]",
          "output": "[1,0]",
          "trigger": "DCNetworkBurstDetector OVERFLOW state fires [1,0] to bytes [64:66]"
        },
        "vectors": [
          {
            "id": "dc-net-throttle-set-event",
            "elements": [
              {
                "value": 1,
                "threshold": 0.5
              },
              {
                "value": 0,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "ALARM",
              "description": "Control signal [1,0]: network burst alarm active — enable throttling",
              "state": "SET"
            },
            "outputVectors": [
              {
                "id": "dc-net-throttle-set-output",
                "vector": [
                  1,
                  0
                ],
                "metadata": {
                  "description": "NETWORK THROTTLE ACTIVE: Traffic shaping engaged",
                  "state": "SET",
                  "logicValue": "HIGH"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "dc-net-throttle-reset-sequence",
        "name": "NETWORK THROTTLE RESET: [0,1] → [0,1]",
        "metadata": {
          "description": "Deactivates network throttle when normal-flow signal [0,1] is received",
          "path": "[0,1] → [0,1]",
          "output": "[0,1]",
          "trigger": "DCNetworkBurstDetector NORMAL_FLOW state fires [0,1] to bytes [64:66]"
        },
        "vectors": [
          {
            "id": "dc-net-throttle-reset-event",
            "elements": [
              {
                "value": 0,
                "threshold": 0.5
              },
              {
                "value": 1,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "SAFE",
              "description": "Control signal [0,1]: network flow normal — disable throttle",
              "state": "RESET"
            },
            "outputVectors": [
              {
                "id": "dc-net-throttle-reset-output",
                "vector": [
                  0,
                  1
                ],
                "metadata": {
                  "description": "NETWORK THROTTLE INACTIVE: Normal traffic flow",
                  "state": "RESET",
                  "logicValue": "LOW"
                }
              }
            ]
          }
        ]
      }
    ],
    "inputSequences": [
      {
        "name": "Network Alarm Activation",
        "pattern": "[0,1] → [1,0]",
        "description": "Simulate DCNetworkBurstDetector firing: normal → alarm",
        "vectors": [
          [
            0,
            1
          ],
          [
            1,
            0
          ]
        ]
      },
      {
        "name": "Network Alarm Recovery",
        "pattern": "[1,0] → [0,1]",
        "description": "Simulate recovery: alarm → normal",
        "vectors": [
          [
            1,
            0
          ],
          [
            0,
            1
          ]
        ]
      },
      {
        "name": "Network Throttle Cycle",
        "pattern": "[0,1] → [1,0] → [1,0] → [0,1]",
        "description": "Full cycle: normal, alarm triggers, persists, recovers",
        "vectors": [
          [
            0,
            1
          ],
          [
            1,
            0
          ],
          [
            1,
            0
          ],
          [
            0,
            1
          ]
        ],
        "metadata": {
          "expectedOutputSequence": "[0,1], [1,0], [1,0], [0,1]",
          "note": "State retained in perceptual space between writes"
        }
      }
    ],
    "matchAlgorithm": "gte"
  }
}

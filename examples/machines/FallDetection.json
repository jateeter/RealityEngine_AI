{
  "version": "1.0.0",
  "machine": {
    "name": "Fall Detection",
    "description": "Classifies motion-sensor events from wearables or in-home cameras into NOMINAL, NEAR-FALL (stumble recovered), or FALL (impact detected). A FALL triggers an immediate RED upstream signal so the local AI can dispatch help.",
    "metadata": {
      "category": "healthcare",
      "domain": "wellness",
      "author": "Reality Engine",
      "created": "2026-04-21T00:00:00Z",
      "workflow": "in-home-fall-detection",
      "eventSpace": "2D binary: [motion_anomaly, impact_confirmed]",
      "outputSpace": "2D binary: {[0,0]=NOMINAL, [1,0]=NEAR_FALL, [1,1]=FALL}",
      "tags": [
        "ces-sequences",
        "ces-sequences-3",
        "elder-care",
        "fall-detection",
        "healthcare",
        "in-home-monitoring",
        "input-sequences",
        "input-sequences-2",
        "safety",
        "startup-loadable",
        "trigger",
        "wellness"
      ],
      "sequenceCount": 3,
      "severity": "life-safety",
      "triggerConfig": {
        "endpoint": "http://localhost:4000/graphql",
        "template": "examples/triggers/graphql_trigger_template.py",
        "processId": "FALL-DETECTION",
        "processName": "Fall Detection",
        "rules": [
          {
            "sequenceId": "fall-nominal",
            "outputMatches": [
              0,
              0
            ],
            "ragStatusCode": "GREEN",
            "processStatus": "ok",
            "description": "No motion anomaly detected"
          },
          {
            "sequenceId": "fall-near-miss",
            "outputMatches": [
              1,
              0
            ],
            "ragStatusCode": "AMBER",
            "processStatus": "warning",
            "description": "Stumble detected but recovered — log and watch"
          },
          {
            "sequenceId": "fall-impact",
            "outputMatches": [
              1,
              1
            ],
            "ragStatusCode": "RED",
            "processStatus": "error",
            "description": "Fall with impact confirmed — dispatch caregiver / emergency contact"
          }
        ]
      },
      "tagging": {
        "schemaVersion": "1.0.0",
        "managedBy": "scripts/manage_machine_tags.mjs",
        "primaryDomain": "healthcare",
        "domainTags": [
          "healthcare",
          "wellness"
        ],
        "family": "fall-detection",
        "machineCode": "fall-detection",
        "capabilityTags": [
          "in-home-monitoring"
        ],
        "workflowTags": [
          "elder-care",
          "fall-detection",
          "safety",
          "trigger"
        ],
        "integrationTags": [
          "healthcare"
        ],
        "validationTags": [
          "ces-sequences",
          "ces-sequences-3",
          "input-sequences",
          "input-sequences-2",
          "startup-loadable"
        ],
        "allTags": [
          "ces-sequences",
          "ces-sequences-3",
          "elder-care",
          "fall-detection",
          "healthcare",
          "in-home-monitoring",
          "input-sequences",
          "input-sequences-2",
          "safety",
          "startup-loadable",
          "trigger",
          "wellness"
        ]
      }
    },
    "arbiterRule": "PASSTHROUGH",
    "perceptualMapping": {
      "input": {
        "offset": 3813,
        "length": 2
      },
      "output": {
        "offset": 1941,
        "length": 2
      }
    },
    "sequences": [
      {
        "id": "fall-nominal",
        "name": "Nominal motion → GREEN",
        "metadata": {
          "description": "No motion anomaly detected"
        },
        "vectors": [
          {
            "id": "fall-ev-nominal",
            "elements": [
              {
                "value": 0,
                "threshold": 0.5
              },
              {
                "value": 0,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "nominal",
              "state": "NOMINAL"
            },
            "outputVectors": [
              {
                "id": "fall-out-nominal",
                "vector": [
                  0,
                  0
                ],
                "metadata": {
                  "ragStatusCode": "GREEN",
                  "state": "NOMINAL"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "fall-near-miss",
        "name": "Near-fall / stumble → AMBER",
        "metadata": {
          "description": "Motion anomaly without confirmed impact"
        },
        "vectors": [
          {
            "id": "fall-ev-near",
            "elements": [
              {
                "value": 1,
                "threshold": 0.5
              },
              {
                "value": 0,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "near-fall",
              "state": "NEAR_FALL"
            },
            "outputVectors": [
              {
                "id": "fall-out-near",
                "vector": [
                  1,
                  0
                ],
                "metadata": {
                  "ragStatusCode": "AMBER",
                  "state": "NEAR_FALL"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "fall-impact",
        "name": "Confirmed fall → RED",
        "metadata": {
          "description": "Motion anomaly + impact confirmed — emergency escalation"
        },
        "vectors": [
          {
            "id": "fall-ev-impact",
            "elements": [
              {
                "value": 1,
                "threshold": 0.5
              },
              {
                "value": 1,
                "threshold": 0.5
              }
            ],
            "isInitial": true,
            "metadata": {
              "name": "impact",
              "state": "FALL"
            },
            "outputVectors": [
              {
                "id": "fall-out-impact",
                "vector": [
                  1,
                  1
                ],
                "metadata": {
                  "ragStatusCode": "RED",
                  "state": "FALL",
                  "lifeSafety": true
                }
              }
            ]
          }
        ]
      }
    ],
    "inputSequences": [
      {
        "name": "Stumble recovered",
        "pattern": "[1,0]",
        "description": "Motion anomaly without impact — expects AMBER trigger",
        "vectors": [
          [
            0,
            0
          ],
          [
            1,
            0
          ],
          [
            0,
            0
          ]
        ]
      },
      {
        "name": "Fall with impact",
        "pattern": "[1,1]",
        "description": "Motion anomaly + impact — expects RED trigger",
        "vectors": [
          [
            0,
            0
          ],
          [
            1,
            0
          ],
          [
            1,
            1
          ],
          [
            0,
            0
          ]
        ]
      }
    ],
    "matchAlgorithm": "gte"
  }
}

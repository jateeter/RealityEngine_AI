    {
      "sensor_id": "dc-thermal",
      "name": "DC Thermal Monitor",
      "type": "sensor",
      "region_offset": 12,
      "region_length": 4,
      "ttl_ms": 120000,
      "fields": [
        "cpu_temp_norm",
        "cpu_load_norm",
        "cpu_throttle_norm",
        "cpu_efficiency_norm"
      ],
      "description": "CPU thermal sensor pack. Feeds DCThermalEscalation CES machine at [12:16]→[60:62].",
      "normalization": {
        "cpu_temp_norm": "0.0=20°C, 0.5=60°C, 1.0=100°C",
        "cpu_load_norm": "0.0=idle, 1.0=100% utilization",
        "cpu_throttle_norm": "wildcard — always set to 0.5",
        "cpu_efficiency_norm": "wildcard — always set to 0.5"
      }
    },
    {

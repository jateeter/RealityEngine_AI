# Qdrant Vector Database
QDRANT_URL=http://localhost:6333

# Vector Configuration
VECTOR_DIMENSION=128
MATCH_THRESHOLD=0.85

# Server Configuration
PORT=3000
NODE_ENV=development

# TLS (optional — only needed when running Node servers directly outside Docker)
# In Docker, TLS is terminated by the nginx tls-proxy; these vars are not set there.
# Generate dev certs first: bash certs/generate-dev-certs.sh
# TLS_CERT_PATH=certs/server.crt
# TLS_KEY_PATH=certs/server.key

# Audit Logging
# AUDIT_LOG_ENABLED=true          # set to "false" to disable entirely
# AUDIT_LOG_LEVEL=2               # 1=MINIMAL, 2=STANDARD, 3=VERBOSE
#   1 (MINIMAL)  — mutating ops (POST/PUT/PATCH/DELETE) + error responses (4xx/5xx) only
#   2 (STANDARD) — all requests with method, path, status, duration, remote IP
#   3 (VERBOSE)  — standard + content-type, content-length, request body preview (Node.js)
# AUDIT_LOG_SERVICE=reality-engine  # service name written into every log entry
